<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>وِعْر – رحلات وفعاليات</title>
<link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&display=swap" rel="stylesheet">
<style>
  :root {
    --sand: #E8DCC8;
    --clay: #C4773B;
    --slate: #2D3A32;
    --moss: #4A6741;
    --dusk: #1A2218;
    --cream: #F5F0E8;
    --mist: #8FA68A;
    --alert: #E05C2A;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Tajawal', sans-serif;
    background: var(--dusk);
    color: var(--cream);
    overflow-x: hidden;
  }

  /* ── NAV ── */
  nav {
    position: fixed; top: 0; width: 100%; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 18px 48px;
    background: rgba(26,34,24,0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(232,220,200,0.1);
  }
  .logo { font-size: 28px; font-weight: 900; letter-spacing: -1px; color: var(--clay); }
  .logo span { color: var(--cream); }
  .nav-links { display: flex; gap: 32px; list-style: none; }
  .nav-links a { color: var(--mist); text-decoration: none; font-size: 15px; font-weight: 500; transition: color 0.2s; }
  .nav-links a:hover { color: var(--cream); }
  .nav-cta { display: flex; gap: 12px; align-items: center; }
  .btn-outline {
    border: 1.5px solid var(--mist); color: var(--cream);
    padding: 8px 20px; border-radius: 6px; font-size: 14px;
    background: transparent; cursor: pointer; font-family: 'Tajawal', sans-serif;
    font-weight: 500; transition: all 0.2s;
  }
  .btn-outline:hover { border-color: var(--cream); }
  .btn-primary {
    background: var(--clay); color: white;
    padding: 9px 22px; border-radius: 6px; font-size: 14px;
    border: none; cursor: pointer; font-family: 'Tajawal', sans-serif;
    font-weight: 700; transition: all 0.2s;
  }
  .btn-primary:hover { background: #d4893e; }

  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    display: flex; flex-direction: column; justify-content: flex-end;
    padding: 0 48px 80px;
    position: relative; overflow: hidden;
  }
  .hero-bg {
    position: absolute; inset: 0;
    background:
      linear-gradient(to top, var(--dusk) 20%, transparent 70%),
      linear-gradient(to left, transparent 50%, rgba(26,34,24,0.6) 100%),
      url('https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?w=1600&q=80') center/cover no-repeat;
  }
  .hero-tag {
    display: inline-block; background: var(--clay);
    color: white; font-size: 12px; font-weight: 700; letter-spacing: 2px;
    padding: 5px 14px; border-radius: 4px; margin-bottom: 20px;
    text-transform: uppercase; width: fit-content;
  }
  .hero h1 {
    font-size: clamp(52px, 8vw, 96px); font-weight: 900; line-height: 1.0;
    letter-spacing: -2px; position: relative; z-index: 1; max-width: 700px;
  }
  .hero h1 em { font-style: normal; color: var(--clay); }
  .hero-sub { margin-top: 20px; font-size: 18px; color: var(--mist); max-width: 480px; position: relative; z-index: 1; line-height: 1.6; }
  .hero-actions { display: flex; gap: 16px; margin-top: 36px; position: relative; z-index: 1; flex-wrap: wrap; }
  .btn-hero {
    background: var(--clay); color: white;
    padding: 15px 36px; border-radius: 8px; font-size: 17px;
    border: none; cursor: pointer; font-family: 'Tajawal', sans-serif;
    font-weight: 700; transition: all 0.2s;
  }
  .btn-hero:hover { background: #d4893e; transform: translateY(-1px); }
  .btn-hero-ghost {
    background: transparent; color: var(--cream);
    padding: 15px 36px; border-radius: 8px; font-size: 17px;
    border: 1.5px solid rgba(232,220,200,0.4); cursor: pointer;
    font-family: 'Tajawal', sans-serif; font-weight: 600; transition: all 0.2s;
  }
  .btn-hero-ghost:hover { border-color: var(--cream); }
  .hero-stats {
    display: flex; gap: 48px; margin-top: 60px; position: relative; z-index: 1;
    padding-top: 32px; border-top: 1px solid rgba(232,220,200,0.15);
  }
  .stat-num { font-size: 32px; font-weight: 900; color: var(--clay); }
  .stat-label { font-size: 13px; color: var(--mist); margin-top: 2px; }

  /* ── SEARCH BAR ── */
  .search-bar {
    background: var(--slate); padding: 32px 48px;
    display: flex; gap: 16px; align-items: flex-end; flex-wrap: wrap;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .search-field { display: flex; flex-direction: column; gap: 6px; flex: 1; min-width: 160px; }
  .search-field label { font-size: 11px; color: var(--mist); font-weight: 600; letter-spacing: 1px; text-transform: uppercase; }
  .search-field select, .search-field input {
    background: rgba(255,255,255,0.07); border: 1.5px solid rgba(255,255,255,0.1);
    color: var(--cream); padding: 11px 14px; border-radius: 6px; font-size: 14px;
    font-family: 'Tajawal', sans-serif; outline: none; transition: border 0.2s;
  }
  .search-field select:focus, .search-field input:focus { border-color: var(--clay); }
  .search-field select option { background: var(--slate); }
  .btn-search {
    background: var(--clay); color: white; padding: 12px 28px; border-radius: 6px; font-size: 15px;
    border: none; cursor: pointer; font-family: 'Tajawal', sans-serif; font-weight: 700; white-space: nowrap; transition: background 0.2s;
  }
  .btn-search:hover { background: #d4893e; }

  /* ── SECTIONS ── */
  section { padding: 80px 48px; }
  .section-header { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 40px; flex-wrap: wrap; gap: 16px; }
  .section-title { font-size: 32px; font-weight: 800; }
  .section-title span { color: var(--clay); }
  .section-link { color: var(--mist); font-size: 14px; text-decoration: none; }
  .section-link:hover { color: var(--cream); }

  /* ── TRIP CARDS ── */
  .trips-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(310px, 1fr)); gap: 24px; }
  .trip-card {
    background: var(--slate); border-radius: 14px; overflow: hidden;
    border: 1px solid rgba(255,255,255,0.06);
    transition: transform 0.25s, box-shadow 0.25s; cursor: pointer;
  }
  .trip-card:hover { transform: translateY(-4px); box-shadow: 0 20px 48px rgba(0,0,0,0.4); }
  .card-img { height: 210px; object-fit: cover; width: 100%; display: block; background: var(--moss); }
  .card-img-wrap { position: relative; }
  .card-badges { position: absolute; top: 14px; right: 14px; display: flex; flex-direction: column; gap: 6px; }
  .badge { font-size: 11px; font-weight: 700; padding: 4px 10px; border-radius: 20px; backdrop-filter: blur(8px); width: fit-content; }
  .badge-diff-easy { background: rgba(74,103,65,0.85); color: #a8d4a0; }
  .badge-diff-mid  { background: rgba(196,119,59,0.85); color: #f4c08a; }
  .badge-diff-hard { background: rgba(180,40,40,0.85); color: #f4a0a0; }
  .badge-new { background: var(--clay); color: white; }
  .card-body { padding: 20px 22px 24px; }
  .card-meta { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
  .card-type { font-size: 11px; color: var(--mist); font-weight: 600; text-transform: uppercase; letter-spacing: 1px; }
  .dot { width: 3px; height: 3px; border-radius: 50%; background: var(--mist); }
  .card-loc { font-size: 11px; color: var(--mist); }
  .card-title { font-size: 18px; font-weight: 800; line-height: 1.3; margin-bottom: 10px; }
  .card-organizer { font-size: 13px; color: var(--mist); margin-bottom: 16px; }
  .card-organizer span { color: var(--cream); font-weight: 600; }
  .card-footer { display: flex; align-items: center; justify-content: space-between; padding-top: 16px; border-top: 1px solid rgba(255,255,255,0.08); }
  .card-price { font-size: 20px; font-weight: 900; color: var(--clay); }
  .card-price small { font-size: 12px; color: var(--mist); font-weight: 400; }
  .card-details { display: flex; gap: 14px; font-size: 12px; color: var(--mist); }
  .detail-item { display: flex; align-items: center; gap: 5px; }
  .stars { color: #F4C542; font-size: 13px; }
  .reviews { font-size: 11px; color: var(--mist); }
  .btn-book {
    background: var(--clay); color: white; padding: 8px 18px; border-radius: 6px; font-size: 13px;
    border: none; cursor: pointer; font-family: 'Tajawal', sans-serif; font-weight: 700; transition: background 0.2s; white-space: nowrap;
  }
  .btn-book:hover { background: #d4893e; }

  /* ── CATEGORIES ── */
  .cats-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 16px; }
  .cat-card {
    background: var(--slate); border-radius: 12px; padding: 28px 20px;
    text-align: center; border: 1.5px solid transparent; cursor: pointer; transition: all 0.2s;
  }
  .cat-card:hover, .cat-card.active { border-color: var(--clay); background: rgba(196,119,59,0.1); }
  .cat-icon { font-size: 36px; margin-bottom: 10px; }
  .cat-name { font-size: 15px; font-weight: 700; }
  .cat-count { font-size: 12px; color: var(--mist); margin-top: 4px; }

  /* ── ORGANIZER CTA ── */
  .organizer-cta {
    background: linear-gradient(135deg, var(--moss) 0%, var(--slate) 60%);
    border-radius: 20px; padding: 60px 48px;
    display: flex; justify-content: space-between; align-items: center;
    gap: 32px; flex-wrap: wrap; border: 1px solid rgba(255,255,255,0.08);
    margin: 0 48px 80px;
  }
  .cta-text h2 { font-size: 34px; font-weight: 900; line-height: 1.2; margin-bottom: 12px; }
  .cta-text p { color: var(--mist); font-size: 16px; max-width: 440px; line-height: 1.6; }
  .btn-cta {
    background: var(--cream); color: var(--dusk); padding: 15px 36px; border-radius: 8px; font-size: 16px;
    border: none; cursor: pointer; font-family: 'Tajawal', sans-serif; font-weight: 800; white-space: nowrap; transition: all 0.2s;
  }
  .btn-cta:hover { background: white; transform: translateY(-1px); }

  /* ── MODAL BASE ── */
  .modal-overlay {
    position: fixed; inset: 0; background: rgba(10,15,10,0.85);
    z-index: 200; display: flex; align-items: center; justify-content: center;
    padding: 20px; opacity: 0; pointer-events: none; transition: opacity 0.25s;
  }
  .modal-overlay.open { opacity: 1; pointer-events: all; }
  .modal {
    background: var(--slate); border-radius: 16px; width: 100%; max-width: 460px;
    padding: 40px; position: relative; transform: translateY(20px); transition: transform 0.25s;
    border: 1px solid rgba(255,255,255,0.08); max-height: 90vh; overflow-y: auto;
  }
  .modal-overlay.open .modal { transform: translateY(0); }
  .modal-close {
    position: absolute; top: 16px; left: 16px;
    background: none; border: none; color: var(--mist); font-size: 22px; cursor: pointer; line-height: 1;
  }
  .modal h2 { font-size: 24px; font-weight: 800; margin-bottom: 24px; }
  .tabs { display: flex; gap: 0; margin-bottom: 28px; border-bottom: 2px solid rgba(255,255,255,0.08); }
  .tab {
    padding: 10px 24px; font-size: 15px; font-weight: 600; cursor: pointer;
    color: var(--mist); border-bottom: 2px solid transparent; margin-bottom: -2px;
    background: none; border-top: none; border-right: none; border-left: none;
    font-family: 'Tajawal', sans-serif; transition: all 0.2s;
  }
  .tab.active { color: var(--clay); border-bottom-color: var(--clay); }
  .form-field { margin-bottom: 18px; }
  .form-field label { display: block; font-size: 13px; color: var(--mist); margin-bottom: 7px; font-weight: 600; }
  .form-field input {
    width: 100%; background: rgba(255,255,255,0.06); border: 1.5px solid rgba(255,255,255,0.1);
    color: var(--cream); padding: 12px 14px; border-radius: 8px; font-size: 15px;
    font-family: 'Tajawal', sans-serif; outline: none; transition: border 0.2s;
  }
  .form-field input:focus { border-color: var(--clay); }
  .btn-submit {
    width: 100%; background: var(--clay); color: white; padding: 14px; border-radius: 8px; font-size: 16px;
    border: none; cursor: pointer; font-family: 'Tajawal', sans-serif; font-weight: 800; transition: background 0.2s; margin-top: 4px;
  }
  .btn-submit:hover { background: #d4893e; }
  .form-footer { text-align: center; margin-top: 16px; font-size: 13px; color: var(--mist); }
  .form-footer a { color: var(--clay); text-decoration: none; cursor: pointer; }

  /* ── REVIEWS ── */
  .reviews-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px; }
  .review-card { background: var(--slate); border-radius: 12px; padding: 24px; border: 1px solid rgba(255,255,255,0.06); }
  .review-stars { color: #F4C542; font-size: 15px; margin-bottom: 12px; }
  .review-text { font-size: 15px; line-height: 1.7; color: var(--sand); margin-bottom: 16px; }
  .reviewer { display: flex; align-items: center; gap: 12px; }
  .reviewer-avatar { width: 38px; height: 38px; border-radius: 50%; background: var(--moss); display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 16px; }
  .reviewer-name { font-weight: 700; font-size: 14px; }
  .reviewer-trip { font-size: 12px; color: var(--mist); }

  /* ── FOOTER ── */
  footer { background: rgba(0,0,0,0.3); border-top: 1px solid rgba(255,255,255,0.06); padding: 48px; text-align: center; }
  .footer-logo { font-size: 32px; font-weight: 900; color: var(--clay); margin-bottom: 8px; }
  .footer-logo span { color: var(--cream); }
  .footer-sub { color: var(--mist); font-size: 14px; margin-bottom: 28px; }
  .footer-links { display: flex; gap: 28px; justify-content: center; flex-wrap: wrap; margin-bottom: 32px; }
  .footer-links a { color: var(--mist); text-decoration: none; font-size: 14px; }
  .footer-links a:hover { color: var(--cream); }
  .footer-copy { color: rgba(143,166,138,0.5); font-size: 12px; }

  /* ── BOOKING MODAL ── */
  .book-modal { max-width: 520px; }
  .book-trip-info { background: rgba(196,119,59,0.1); border-radius: 10px; padding: 16px; margin-bottom: 24px; border: 1px solid rgba(196,119,59,0.2); }
  .book-trip-name { font-weight: 800; font-size: 16px; margin-bottom: 4px; }
  .book-trip-meta { font-size: 13px; color: var(--mist); }
  .payment-methods { display: flex; gap: 10px; margin-bottom: 20px; }
  .pay-btn {
    flex: 1; padding: 10px; border-radius: 8px; border: 1.5px solid rgba(255,255,255,0.1);
    background: rgba(255,255,255,0.04); color: var(--mist); cursor: pointer;
    font-family: 'Tajawal', sans-serif; font-size: 13px; font-weight: 600; transition: all 0.2s; text-align: center;
  }
  .pay-btn.active { border-color: var(--clay); color: var(--clay); background: rgba(196,119,59,0.1); }
  .total-row { display: flex; justify-content: space-between; align-items: center; padding: 14px 0; border-top: 1px solid rgba(255,255,255,0.08); margin-top: 8px; }
  .total-label { color: var(--mist); font-size: 14px; }
  .total-amount { font-size: 24px; font-weight: 900; color: var(--clay); }

  /* ── TRIP DETAIL MODAL ── */
  .detail-overlay {
    position: fixed; inset: 0; background: rgba(10,15,10,0.9);
    z-index: 300; display: flex; align-items: flex-start; justify-content: center;
    padding: 20px; opacity: 0; pointer-events: none; transition: opacity 0.25s; overflow-y: auto;
  }
  .detail-overlay.open { opacity: 1; pointer-events: all; }
  .detail-modal {
    background: var(--slate); border-radius: 20px; width: 100%; max-width: 820px;
    position: relative; border: 1px solid rgba(255,255,255,0.08);
    transform: translateY(24px); transition: transform 0.3s; margin: auto; overflow: hidden;
  }
  .detail-overlay.open .detail-modal { transform: translateY(0); }
  .detail-hero-img { width: 100%; height: 300px; object-fit: cover; display: block; }
  .detail-hero-overlay {
    position: relative; margin-top: -80px; padding: 0 36px 0;
    display: flex; align-items: flex-end; justify-content: space-between; gap: 16px; flex-wrap: wrap;
  }
  .detail-badges-top { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 12px; }
  .detail-title-block { flex: 1; }
  .detail-title { font-size: 26px; font-weight: 900; line-height: 1.2; text-shadow: 0 2px 12px rgba(0,0,0,0.5); }
  .detail-organizer { font-size: 14px; color: var(--mist); margin-top: 6px; }
  .detail-organizer strong { color: var(--cream); }
  .detail-rating {
    display: flex; align-items: center; gap: 6px;
    background: rgba(26,34,24,0.85); border-radius: 10px; padding: 8px 14px;
    white-space: nowrap; align-self: flex-end; margin-bottom: 12px;
  }
  .detail-rating .stars { color: #F4C542; font-size: 15px; }
  .detail-rating span { font-weight: 800; font-size: 15px; }
  .detail-rating small { color: var(--mist); font-size: 12px; }
  .detail-body { padding: 28px 36px 120px; }
  .detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 28px; }
  .detail-info-card {
    background: rgba(255,255,255,0.04); border-radius: 12px; padding: 16px 18px;
    border: 1px solid rgba(255,255,255,0.07);
  }
  .detail-info-label { font-size: 11px; color: var(--mist); font-weight: 700; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 6px; }
  .detail-info-value { font-size: 15px; font-weight: 700; line-height: 1.4; }
  .detail-info-value.clay { color: var(--clay); }
  .detail-section { margin-bottom: 24px; }
  .detail-section-title {
    font-size: 14px; font-weight: 700; color: var(--mist); letter-spacing: 1px;
    text-transform: uppercase; margin-bottom: 14px;
    padding-bottom: 8px; border-bottom: 1px solid rgba(255,255,255,0.07);
  }
  .detail-dates { display: flex; flex-direction: column; gap: 10px; }
  .detail-date-item {
    display: flex; align-items: center; justify-content: space-between;
    background: rgba(255,255,255,0.04); border-radius: 10px; padding: 12px 16px;
    border: 1px solid rgba(255,255,255,0.07);
  }
  .detail-date-item.active-date { border-color: rgba(196,119,59,0.4); background: rgba(196,119,59,0.08); }
  .date-label { font-size: 14px; font-weight: 600; }
  .date-seats { font-size: 12px; color: var(--mist); }
  .date-seats.low { color: #E05C2A; }
  .includes-grid { display: flex; flex-wrap: wrap; gap: 10px; }
  .include-tag {
    display: flex; align-items: center; gap: 6px;
    background: rgba(74,103,65,0.2); border: 1px solid rgba(74,103,65,0.4);
    border-radius: 20px; padding: 6px 14px; font-size: 13px; font-weight: 600; color: #a8d4a0;
  }
  .exclude-tag {
    display: flex; align-items: center; gap: 6px;
    background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1);
    border-radius: 20px; padding: 6px 14px; font-size: 13px; font-weight: 600; color: var(--mist);
  }
  .bring-list { display: flex; flex-wrap: wrap; gap: 8px; }
  .bring-item {
    background: rgba(255,255,255,0.05); border-radius: 8px; padding: 7px 14px;
    font-size: 13px; color: var(--sand); border: 1px solid rgba(255,255,255,0.07);
  }
  .map-btn {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(196,119,59,0.15); border: 1.5px solid rgba(196,119,59,0.4);
    color: var(--clay); border-radius: 8px; padding: 10px 18px;
    font-size: 14px; font-weight: 700; font-family: 'Tajawal', sans-serif;
    cursor: pointer; text-decoration: none; transition: all 0.2s;
  }
  .map-btn:hover { background: rgba(196,119,59,0.25); }
  .detail-footer {
    position: sticky; bottom: 0;
    background: var(--slate); border-top: 1px solid rgba(255,255,255,0.08);
    padding: 18px 36px;
    display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap;
  }
  .detail-price-block .price-main { font-size: 28px; font-weight: 900; color: var(--clay); }
  .detail-price-block .price-sub { font-size: 13px; color: var(--mist); margin-top: 2px; }
  .btn-detail-book {
    background: var(--clay); color: white; padding: 14px 36px; border-radius: 10px; font-size: 17px;
    border: none; cursor: pointer; font-family: 'Tajawal', sans-serif; font-weight: 800; transition: all 0.2s;
  }
  .btn-detail-book:hover { background: #d4893e; transform: translateY(-1px); }
  .detail-close {
    position: absolute; top: 16px; left: 16px; z-index: 10;
    background: rgba(26,34,24,0.75); backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,0.15); border-radius: 50%;
    width: 36px; height: 36px; display: flex; align-items: center; justify-content: center;
    color: var(--cream); font-size: 18px; cursor: pointer; line-height: 1;
  }
  .guide-card {
    display: flex; align-items: center; gap: 14px;
    background: rgba(255,255,255,0.04); border-radius: 12px; padding: 14px 16px;
    border: 1px solid rgba(255,255,255,0.07);
  }
  .guide-avatar {
    width: 44px; height: 44px; border-radius: 50%; background: var(--moss);
    display: flex; align-items: center; justify-content: center;
    font-weight: 900; font-size: 18px; flex-shrink: 0;
  }
  .guide-name { font-weight: 700; font-size: 15px; }
